{
  "name": "rotation-app",
  "private": true,
  "version": "0.29.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "npm run lint:frontend && npm run lint:server",
    "lint:frontend": "eslint src vite.config.ts vitest.config.ts",
    "lint:server": "npm --prefix server run lint",
    "preview": "vite preview",
    "test": "npm run test:frontend && npm run test:server",
    "test:frontend": "vitest run --config vitest.config.ts",
    "test:server": "npm --prefix server test",
    "test:watch": "vitest --config vitest.config.ts",
    "validate": "npm run lint && npm test && npm run build && npm --prefix server run build"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
