:80 {
    # Healthcheck endpoint (served directly by Caddy)
    handle /health {
        respond "ok" 200
    }

    # API proxy to backend service
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy rotation-api:3001 {
            # Overwrite any client-supplied value; the browser never receives this secret.
            header_up X-Rotation-Write-Token {$ROTATION_WRITE_TOKEN}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    # Playback routes proxy to backend service (Workstream 89D)
    handle /playback/* {
        reverse_proxy rotation-api:3001 {
            header_up X-Rotation-Write-Token {$ROTATION_WRITE_TOKEN}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    # Static SPA files
    handle {
        root * /usr/share/caddy
        file_server
        try_files {path} /index.html
    }
}
